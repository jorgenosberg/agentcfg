---
const base = import.meta.env.BASE_URL;

const features = [
  {
    title: 'Discovery & import',
    body:
      'Ships a built-in catalog of known agent install dirs. Discovery is opt-in, so nothing ' +
      'outside your source tree is touched unless you ask.',
    href: `${base}guides/discovery-and-import/`,
  },
  {
    title: 'Link or copy',
    body:
      'Symlink for a single source of truth with instant propagation, or copy for agents ' +
      "that can't resolve symlinks. Configurable globally or per target.",
    href: `${base}guides/link-vs-copy/`,
  },
  {
    title: 'One source tree',
    body:
      'Skills, hooks, and shared instruction files (CLAUDE.md, AGENTS.md) live in one ' +
      'user-defined directory, installed out to every agent that needs them.',
    href: `${base}guides/source-layout/`,
  },
  {
    title: 'Sandboxed by default',
    body:
      'Point AGENTCFG_HOME anywhere to try commands against a throwaway home directory. ' +
      'Your real agent configs are never touched during testing.',
    href: `${base}guides/sandbox-testing/`,
  },
];
---

<section class="features">
  <div class="grid">
    {
      features.map((f) => (
        <a class="card" href={f.href}>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </a>
      ))
    }
  </div>
</section>

<style>
  .features {
    max-width: 46rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 40rem) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .card {
    display: block;
    border: 1px solid var(--landing-border);
    border-radius: 8px;
    padding: 1.15rem 1.25rem;
    text-decoration: none;
  }

  .card:hover {
    background: var(--landing-bg-raised);
  }

  .card h3 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--landing-fg);
  }

  .card p {
    margin: 0;
    color: var(--landing-fg-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }
</style>
