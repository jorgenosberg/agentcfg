---
const base = import.meta.env.BASE_URL;

const features = [
  {
    title: 'One source tree',
    body:
      'Skills, hooks, and instruction files like CLAUDE.md and AGENTS.md live in one ' +
      'directory you choose, and get installed into each agent from there.',
    href: `${base}guides/source-layout/`,
  },
  {
    title: 'Link or copy',
    body:
      "Symlink so edits show up everywhere immediately, or copy for agents that can't " +
      'follow symlinks. Set the strategy globally or per target.',
    href: `${base}guides/link-vs-copy/`,
  },
  {
    title: 'Discovery & import',
    body:
      'agentcfg knows the usual install directories (~/.claude, ~/.codex, and so on) and ' +
      'can import what it finds there into your source tree. Nothing is scanned unless you ask.',
    href: `${base}guides/discovery-and-import/`,
  },
  {
    title: 'Sandbox mode',
    body:
      'Set AGENTCFG_HOME to a throwaway directory and every command reads and writes ' +
      'only there. Try things out without touching your real agent configs.',
    href: `${base}guides/sandbox-testing/`,
  },
];
---

<section class="features">
  <div class="grid">
    {
      features.map((f) => (
        <a class="card" href={f.href}>
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </a>
      ))
    }
  </div>
</section>

<style>
  .features {
    max-width: 46rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  @media (max-width: 40rem) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .card {
    display: block;
    border: 1px solid var(--landing-border);
    border-radius: 8px;
    padding: 1.15rem 1.25rem;
    text-decoration: none;
  }

  .card:hover {
    background: var(--landing-bg-raised);
  }

  .card h3 {
    margin: 0 0 0.4rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--landing-fg);
  }

  .card p {
    margin: 0;
    color: var(--landing-fg-muted);
    font-size: 0.9rem;
    line-height: 1.55;
  }
</style>
