---
const commands = [
  {
    label: 'Homebrew',
    code: 'brew install jorgenosberg/tap/agentcfg       # CLI\nbrew install jorgenosberg/tap/lazyagentcfg   # TUI',
  },
  {
    label: 'go install',
    code:
      'go install github.com/jorgenosberg/agentcfg/cmd/agentcfg@latest\n' +
      'go install github.com/jorgenosberg/agentcfg/cmd/lazyagentcfg@latest',
  },
  {
    label: 'From source',
    code: 'git clone https://github.com/jorgenosberg/agentcfg\ncd agentcfg && make build',
  },
];
---

<section class="install">
  <h2>Install</h2>
  <p class="note">Go installs and source builds require Go 1.24 or newer.</p>
  <div class="blocks">
    {
      commands.map((c) => (
        <div class="block">
          <p class="block-label">{c.label}</p>
          <pre><code>{c.code}</code></pre>
        </div>
      ))
    }
  </div>
</section>

<style>
  .install {
    max-width: 46rem;
    margin: 0 auto 4rem;
    padding: 0 1.5rem;
  }

  h2 {
    font-size: 1.35rem;
    letter-spacing: -0.01em;
    color: var(--landing-fg);
    margin: 0 0 0.25rem;
  }

  .note {
    color: var(--landing-fg-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .blocks {
    display: grid;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .block {
    background: var(--landing-bg-raised);
    border: 1px solid var(--landing-border);
    border-radius: 8px;
    padding: 0.9rem 1.1rem;
  }

  .block-label {
    font-family: var(--landing-font-mono);
    font-size: 0.75rem;
    color: var(--landing-fg-muted);
    margin: 0 0 0.6rem;
  }

  pre {
    margin: 0;
    overflow-x: auto;
    font-family: var(--landing-font-mono);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--landing-text);
  }
</style>
