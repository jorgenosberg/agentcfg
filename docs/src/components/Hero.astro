---
const base = import.meta.env.BASE_URL;
---

<section class="hero">
  <p class="eyebrow">CLI + TUI</p>
  <h1>Sync skills, hooks, and instruction files across AI coding agents</h1>
  <p class="lede">
    One user-defined source tree, symlinked or copied into Claude Code, Codex, Copilot,
    Gemini, OpenCode, and more. Most AI agent configs are just plain files — agentcfg
    manages them as such.
  </p>
  <div class="cta">
    <a class="button" href={`${base}getting-started/installation/`}>Get started</a>
    <a class="button secondary" href="https://github.com/jorgenosberg/agentcfg">View on GitHub</a>
  </div>
</section>

<style>
  .hero {
    max-width: 46rem;
    margin: 4rem auto 3rem;
    padding: 0 1.5rem;
    text-align: center;
  }

  .eyebrow {
    font-family: var(--landing-font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--landing-accent);
    margin-bottom: 0.75rem;
  }

  h1 {
    font-size: 2.25rem;
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .lede {
    color: var(--landing-fg-muted);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .cta {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  .button {
    display: inline-block;
    padding: 0.6rem 1.25rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    background: var(--landing-accent);
    color: #05140e;
  }

  .button.secondary {
    background: transparent;
    color: var(--landing-fg);
    border: 1px solid var(--landing-border);
  }
</style>
