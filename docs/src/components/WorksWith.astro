---
// Third-party brand marks (lobe-icons set) — check each vendor's brand
// guidelines before using this strip in a marketing/promotional context
// beyond nominative use. Imported as components so currentColor icons
// (Copilot, OpenCode) inherit the page text color in both themes.
import ClaudeCode from '../assets/logos/claude-code.svg';
import Codex from '../assets/logos/codex.svg';
import Copilot from '../assets/logos/copilot.svg';
import Gemini from '../assets/logos/gemini.svg';
import Antigravity from '../assets/logos/antigravity.svg';
import OpenCode from '../assets/logos/opencode.svg';

const agents = [
  { name: 'Claude Code', Icon: ClaudeCode },
  { name: 'Codex', Icon: Codex },
  { name: 'Copilot', Icon: Copilot },
  { name: 'Gemini CLI', Icon: Gemini },
  { name: 'Antigravity', Icon: Antigravity },
  { name: 'OpenCode', Icon: OpenCode },
];
---

<section class="works-with">
  <p class="label">Works with</p>
  <div class="logos">
    {
      agents.map(({ name, Icon }) => (
        <span class="logo">
          <Icon aria-hidden="true" />
          {name}
        </span>
      ))
    }
  </div>
</section>

<style>
  .works-with {
    max-width: 46rem;
    margin: 0 auto 4rem;
    padding: 0 1.5rem;
    text-align: center;
  }

  .label {
    font-size: 0.8rem;
    color: var(--landing-fg-muted);
    margin-bottom: 1rem;
  }

  .logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem 1.75rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--landing-fg-muted);
    font-size: 0.9rem;
  }

  .logo :global(svg) {
    width: 18px;
    height: 18px;
    color: var(--landing-fg);
  }
</style>
