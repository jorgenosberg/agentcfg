# Refuse to install a package version published less than this many minutes
# ago — the standard defense against just-published supply-chain compromises
# (most get caught and pulled within hours). 1440 = 24h.
minimum-release-age=1440

# pnpm v10+ already blocks dependency lifecycle scripts by default (the main
# hardening win vs npm). Deliberately not overriding that here — if a new
# dependency genuinely needs its postinstall script, allowlist it explicitly
# with `pnpm approve-builds` rather than disabling this check globally.
