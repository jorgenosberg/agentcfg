# Block all dependency lifecycle scripts (npm has no allowlist mechanism, so
# this is all-or-nothing). Astro/sharp work without scripts: they ship
# prebuilt binaries as optional platform dependencies.
ignore-scripts=true

# Refuse to install package versions published less than this many days ago —
# the standard defense against just-published supply-chain compromises
# (most get caught and pulled within hours).
min-release-age=1
